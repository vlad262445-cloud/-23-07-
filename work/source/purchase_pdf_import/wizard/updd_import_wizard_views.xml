<odoo>
  <record id="view_purchase_updd_import_wizard_form" model="ir.ui.view">
    <field name="name">purchase.updd.import.wizard.form</field>
    <field name="model">purchase.updd.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Распознавание УПД">
        <field name="state" invisible="1"/>
        <group invisible="state != 'draft'">
          <field name="purchase_order_id"
                 domain="[('state', 'in', ('purchase', 'done')), ('updd_line_ids', '=', False)]"/>
          <field name="pdf_filename" invisible="1"/>
          <field name="pdf_file" filename="pdf_filename"/>
        </group>
        <group invisible="state == 'draft'">
          <div class="alert alert-warning" role="alert" invisible="not extraction_warning">
            <strong>⚠ ИИ не уверен в распознавании:</strong>
            <field name="extraction_warning" readonly="1" nolabel="1" class="oe_inline"/>
            - проверьте распознанные поля ниже по самому документу перед подтверждением.
          </div>
          <div class="alert alert-warning" role="alert" invisible="not inn_mismatch">
            ИНН продавца по документу не совпадает с ИНН поставщика по заказу - проверьте документ перед подтверждением.
          </div>
          <div class="alert alert-info" role="alert" invisible="not match_confidence or match_confidence == 'none'">
            Заказ подобран автоматически по составу товаров (уверенность: <field name="match_confidence" readonly="1" nolabel="1" class="oe_inline"/>). Если ИИ ошибся - выберите другой заказ ниже и нажмите "Обновить товары".
          </div>
          <div class="alert alert-warning" role="alert" invisible="match_confidence != 'none'">
            Не удалось автоматически подобрать заказ. Если он всё же есть - выберите его вручную ниже и нажмите
            "Обновить товары". Если товар пришёл без заказа (в обход обычного процесса) - просто нажмите
            "Подтвердить УПД": приёмка будет создана и проведена напрямую по товарам ниже.
          </div>
          <group>
            <field name="purchase_order_id"
                 domain="[('state', 'in', ('purchase', 'done')), ('updd_line_ids', '=', False)]"/>
            <button name="action_refresh_lines" string="Обновить товары" type="object" class="btn-secondary" invisible="not purchase_order_id"/>
          </group>
          <group>
            <field name="recognized_amount" readonly="1"/>
            <field name="expected_amount" readonly="1"/>
            <field name="recognized_date" readonly="1"/>
            <field name="recognized_number" readonly="1"/>
          </group>
          <group>
            <field name="recognized_seller_name" readonly="1"/>
            <field name="recognized_seller_inn" readonly="1"/>
            <field name="partner_expected_inn" readonly="1"/>
          </group>
          <field name="line_ids" invisible="not line_ids">
            <list editable="bottom">
              <field name="product_id" readonly="1"/>
              <field name="quantity" readonly="1"/>
              <field name="suggested_location_id" string="Куда положить"/>
            </list>
          </field>
          <field name="match_note" readonly="1" invisible="not match_note"/>
        </group>
        <footer>
          <button name="action_import" string="Распознать" type="object" class="btn-primary" invisible="state != 'draft'"/>
          <button name="action_confirm" string="Подтвердить УПД" type="object" class="btn-primary" invisible="state != 'recognized'"/>
          <button string="Закрыть" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_purchase_updd_import_wizard" model="ir.actions.act_window">
    <field name="name">Загрузить УПД</field>
    <field name="res_model">purchase.updd.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
