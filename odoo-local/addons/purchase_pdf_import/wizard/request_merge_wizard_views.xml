<odoo>
  <record id="view_purchase_request_merge_wizard_form" model="ir.ui.view">
    <field name="name">purchase.request.merge.wizard.form</field>
    <field name="model">purchase.request.merge.wizard</field>
    <field name="arch" type="xml">
      <form string="Объединить заявки">
        <p>
          Позиции всех выбранных заявок, кроме заявки-цели, переедут в неё -
          исходные заявки перейдут в статус "Объединена" и останутся видны
          через "Объединено в" у того, кто их подавал.
        </p>
        <!-- force_save="1" - без него веб-клиент "теряет" это readonly-поле
             целиком при создании визарда, так как оно пришло не через
             собственный default поля, а через default_get (тот же приём,
             что и в request_split_wizard_views.xml, воспроизведено там же
             2026-07-13: INSERT ушёл без данных поля и упал на пустом значении). -->
        <field name="request_ids" readonly="1" force_save="1">
          <list create="false" delete="false">
            <field name="name"/>
            <field name="requested_by"/>
            <field name="department_id"/>
            <field name="items_preview"/>
          </list>
        </field>
        <group>
          <field name="target_request_id"/>
          <field name="reason" placeholder="Например: слишком мелкая позиция для отдельного заказа поставщику"/>
        </group>
        <footer>
          <button name="action_merge" type="object" string="Объединить" class="btn-primary"/>
          <button string="Отмена" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_purchase_request_merge_wizard" model="ir.actions.act_window">
    <field name="name">Объединить заявки</field>
    <field name="res_model">purchase.request.merge.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="binding_model_id" ref="model_purchase_request"/>
    <field name="binding_view_types">list</field>
    <field name="groups_id" eval="[(4, ref('purchase.group_purchase_user')), (4, ref('purchase_pdf_import.group_chief_buyer'))]"/>
  </record>
</odoo>
