<odoo>
  <record id="view_purchase_payment_import_wizard_form" model="ir.ui.view">
    <field name="name">purchase.payment.import.wizard.form</field>
    <field name="model">purchase.payment.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Распознавание платёжки">
        <field name="state" invisible="1"/>
        <field name="request_id" invisible="1"/>
        <group invisible="state != 'draft'">
          <field name="purchase_order_id"/>
          <field name="pdf_filename" invisible="1"/>
          <field name="pdf_file" filename="pdf_filename"/>
        </group>
        <group invisible="state == 'draft'">
          <div class="alert alert-warning" role="alert" invisible="not inn_mismatch">
            ИНН получателя по документу не совпадает с ИНН поставщика по заказу - проверьте платёж перед подтверждением.
          </div>
          <group>
            <field name="recognized_amount" readonly="1"/>
            <field name="expected_amount" readonly="1"/>
            <field name="recognized_date" readonly="1"/>
            <field name="recognized_payment_number" readonly="1"/>
          </group>
          <group>
            <field name="recognized_recipient_name" readonly="1"/>
            <field name="recognized_recipient_inn" readonly="1"/>
            <field name="partner_expected_inn" readonly="1"/>
            <field name="recognized_purpose" readonly="1"/>
          </group>
        </group>
        <footer>
          <button name="action_import" string="Распознать" type="object" class="btn-primary" invisible="state != 'draft'"/>
          <button name="action_confirm" string="Подтвердить оплату" type="object" class="btn-primary" invisible="state != 'recognized'"/>
          <button string="Закрыть" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_purchase_payment_import_wizard" model="ir.actions.act_window">
    <field name="name">Загрузить платёжку</field>
    <field name="res_model">purchase.payment.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
