<odoo>
  <record id="view_purchase_pdf_import_wizard_form" model="ir.ui.view">
    <field name="name">purchase.pdf.import.wizard.form</field>
    <field name="model">purchase.pdf.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Импорт заказа на закупку из PDF">
        <field name="state" invisible="1"/>
        <group invisible="state != 'draft'">
          <field name="vendor_id"/>
          <field name="payment_type"/>
          <field name="pdf_filename" invisible="1"/>
          <field name="pdf_file" filename="pdf_filename"/>
        </group>
        <group invisible="state != 'done'">
          <field name="result_order_id" readonly="1"/>
          <field name="log" readonly="1"/>
        </group>
        <footer>
          <button name="action_import" string="Импортировать" type="object" class="btn-primary" invisible="state != 'draft'"/>
          <!-- Запасной путь, если ИИ недоступен - берёт позиции прямо из
               заявки (без распознавания цены), человек дозаполняет их на
               заказе сам. Не требует загруженного PDF. -->
          <button name="action_import_manual" string="Оформить без ИИ" type="object" class="btn-secondary"
                  confirm="Заказ будет создан из позиций заявки без распознавания цены - придётся заполнить цены вручную на самом заказе. Продолжить?"
                  invisible="state != 'draft'"/>
          <button name="action_view_order" string="Открыть заказ" type="object" class="btn-primary" invisible="state != 'done'"/>
          <button string="Закрыть" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_purchase_pdf_import_wizard" model="ir.actions.act_window">
    <field name="name">Импорт из PDF</field>
    <field name="res_model">purchase.pdf.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
