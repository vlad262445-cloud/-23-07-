<odoo>
  <!-- Экран "Потребность" (п. 10.7/10.8 ТЗ) - тип x размер, сколько выдать
       в ближайшие 3 месяца по нормам. Таблица-снимок, обновляемая кнопкой
       или ежедневным cron (см. hr.employee._cron_check_workwear_overdue),
       а не живой SQL-view - см. обоснование в models/
       hr_workwear_requirement_report.py и NOTES.md. -->
  <record id="view_hr_workwear_requirement_list" model="ir.ui.view">
    <field name="name">hr.workwear.requirement.line.list</field>
    <field name="model">hr.workwear.requirement.line</field>
    <field name="arch" type="xml">
      <list string="Потребность в спецодежде">
        <field name="employee_id"/>
        <field name="department_id"/>
        <field name="type_id"/>
        <field name="size_id"/>
        <field name="quantity"/>
        <field name="due_date"/>
        <field name="is_overdue" widget="boolean_toggle" readonly="1"/>
      </list>
    </field>
  </record>

  <record id="view_hr_workwear_requirement_pivot" model="ir.ui.view">
    <field name="name">hr.workwear.requirement.line.pivot</field>
    <field name="model">hr.workwear.requirement.line</field>
    <field name="arch" type="xml">
      <pivot string="Потребность в спецодежде">
        <field name="type_id" type="row"/>
        <field name="size_id" type="col"/>
        <field name="quantity" type="measure"/>
      </pivot>
    </field>
  </record>

  <record id="action_hr_workwear_requirement" model="ir.actions.act_window">
    <field name="name">Потребность</field>
    <field name="res_model">hr.workwear.requirement.line</field>
    <field name="view_mode">list,pivot</field>
    <field name="help" type="html">
      <p>Что и в каких размерах закупать в ближайшие 3 месяца по нормам.
      Обновляется автоматически раз в сутки, или вручную - действие
      "Обновить потребность" в меню "Действие".</p>
    </field>
  </record>

  <record id="action_hr_workwear_requirement_refresh" model="ir.actions.server">
    <field name="name">Обновить потребность</field>
    <field name="model_id" ref="model_hr_workwear_requirement_line"/>
    <field name="binding_model_id" ref="model_hr_workwear_requirement_line"/>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="code">model._refresh()</field>
  </record>

  <record id="action_hr_workwear_requirement_create_request" model="ir.actions.server">
    <field name="name">Создать заявку на закупку</field>
    <field name="model_id" ref="model_hr_workwear_requirement_line"/>
    <field name="binding_model_id" ref="model_hr_workwear_requirement_line"/>
    <field name="binding_view_types">list</field>
    <field name="state">code</field>
    <field name="code">action = records.action_create_purchase_request() if records else False</field>
  </record>

  <!-- "Расход" (п. 10.7 ТЗ, экран 5) - тип x отдел x период, выданное
       количество. Обычный pivot по уже существующим related+store полям
       строки выдачи, без отдельной отчётной модели. -->
  <record id="view_hr_workwear_issue_line_consumption_pivot" model="ir.ui.view">
    <field name="name">hr.workwear.issue.line.consumption.pivot</field>
    <field name="model">hr.workwear.issue.line</field>
    <field name="arch" type="xml">
      <pivot string="Расход спецодежды">
        <field name="type_id" type="row"/>
        <field name="employee_id" invisible="1"/>
        <field name="issue_date" interval="month" type="col"/>
        <field name="quantity" type="measure"/>
      </pivot>
    </field>
  </record>

  <record id="action_hr_workwear_issue_line_consumption" model="ir.actions.act_window">
    <field name="name">Расход</field>
    <field name="res_model">hr.workwear.issue.line</field>
    <field name="view_mode">pivot</field>
    <field name="view_id" ref="view_hr_workwear_issue_line_consumption_pivot"/>
  </record>
</odoo>
