<odoo>
  <record id="view_hr_workwear_norm_list" model="ir.ui.view">
    <field name="name">hr.workwear.norm.list</field>
    <field name="model">hr.workwear.norm</field>
    <field name="arch" type="xml">
      <list string="Нормы выдачи" editable="bottom">
        <field name="job_id"/>
        <field name="department_id"/>
        <field name="type_id"/>
        <field name="quantity"/>
        <field name="period_months"/>
      </list>
    </field>
  </record>

  <record id="action_hr_workwear_norm" model="ir.actions.act_window">
    <field name="name">Нормы выдачи</field>
    <field name="res_model">hr.workwear.norm</field>
    <field name="view_mode">list</field>
    <field name="help" type="html">
      <p>Норма задаётся либо на должность, либо на подразделение (ровно на
      одно из двух) - например, слесарь → комбинезон 1 шт / 12 мес.</p>
    </field>
  </record>
</odoo>
