<odoo>
  <template id="report_workwear_issue_slip">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="issue">
        <t t-call="web.external_layout">
          <div class="page">
            <h2>Ведомость выдачи <span t-field="issue.name"/></h2>
            <table class="table table-sm">
              <tr><td>Сотрудник</td><td><span t-field="issue.employee_id.name"/></td></tr>
              <tr><td>Дата выдачи</td><td><span t-field="issue.issue_date"/></td></tr>
              <tr><td>Кто выдал</td><td><span t-field="issue.issued_by.name"/></td></tr>
            </table>
            <table class="table table-bordered table-sm">
              <thead>
                <tr>
                  <th>Тип</th>
                  <th>Размер</th>
                  <th>Кол-во</th>
                  <th>Срок носки</th>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="issue.line_ids" t-as="line">
                  <tr>
                    <td><span t-field="line.type_id.name"/></td>
                    <td><span t-field="line.size_id.name"/></td>
                    <td><span t-field="line.quantity"/></td>
                    <td><span t-field="line.wear_period_months"/> мес.</td>
                  </tr>
                </t>
              </tbody>
            </table>
            <div class="mt-5">Получил: _____________________ / <span t-field="issue.employee_id.name"/> /</div>
          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
