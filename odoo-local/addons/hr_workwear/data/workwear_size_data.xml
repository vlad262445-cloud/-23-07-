  </record>
  <record id="workwear_size_numeric_52" model="hr.workwear.size">
    <field name="name">52</field><field name="scale">numeric</field><field name="sequence">50</field>
  </record>
  <record id="workwear_size_numeric_54" model="hr.workwear.size">
