<odoo noupdate="1">
  <!-- Справочник значений размеров (п. 10.4 ТЗ) - не свободный текст,
       иначе в базе появятся "M"/"м"/"Эм" и "48-50" как разные размеры
       (та же беда, от которой модуль 8 защищает поставщиков). Один
       набор на каждую шкалу (size_scale), домен на hr.employee.workwear.
       size/строке выдачи фильтрует по типу. Шкала "none" (безразмерное)
       намеренно без записей - для неё size_id остаётся необязательным. -->

  <!-- alpha: халат, футболка, перчатки -->
  <record id="workwear_size_alpha_xs" model="hr.workwear.size">
    <field name="name">XS</field><field name="scale">alpha</field><field name="sequence">10</field>
  </record>
  <record id="workwear_size_alpha_s" model="hr.workwear.size">
    <field name="name">S</field><field name="scale">alpha</field><field name="sequence">20</field>
  </record>
  <record id="workwear_size_alpha_m" model="hr.workwear.size">
    <field name="name">M</field><field name="scale">alpha</field><field name="sequence">30</field>
  </record>
  <record id="workwear_size_alpha_l" model="hr.workwear.size">
    <field name="name">L</field><field name="scale">alpha</field><field name="sequence">40</field>
  </record>
  <record id="workwear_size_alpha_xl" model="hr.workwear.size">
    <field name="name">XL</field><field name="scale">alpha</field><field name="sequence">50</field>
  </record>
  <record id="workwear_size_alpha_xxl" model="hr.workwear.size">
    <field name="name">XXL</field><field name="scale">alpha</field><field name="sequence">60</field>
  </record>

  <!-- numeric: комбинезон, куртка -->
  <record id="workwear_size_numeric_44" model="hr.workwear.size">
    <field name="name">44</field><field name="scale">numeric</field><field name="sequence">10</field>
  </record>
  <record id="workwear_size_numeric_46" model="hr.workwear.size">
    <field name="name">46</field><field name="scale">numeric</field><field name="sequence">20</field>
  </record>
