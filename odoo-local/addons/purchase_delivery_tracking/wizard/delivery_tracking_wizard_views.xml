<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_purchase_delivery_tracking_wizard_form" model="ir.ui.view">
    <field name="name">purchase.delivery.tracking.wizard.form</field>
    <field name="model">purchase.delivery.tracking.wizard</field>
    <field name="arch" type="xml">
      <form string="Оформить доставку">
        <field name="purchase_order_id" invisible="1"/>
        <field name="delivery_method_has_tracking" invisible="1"/>
        <group>
          <field name="delivery_method_id" options="{'no_quick_create': false}"/>
          <field name="tracking_number" invisible="not delivery_method_has_tracking"/>
          <field name="shipped_date"/>
        </group>
        <footer>
          <button name="action_confirm" type="object" string="Подтвердить" class="btn-primary"/>
          <button string="Отмена" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
