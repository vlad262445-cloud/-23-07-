<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_purchase_order_form_inherit_delivery_tracking" model="ir.ui.view">
    <field name="name">purchase.order.form.inherit.delivery.tracking</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase_pdf_import.view_purchase_order_form_inherit_pdf_import"/>
    <field name="arch" type="xml">
      <!-- Wizard вместо голого confirm= - см. п. 5.2 ТЗ. Условие видимости
           can_arrange_delivery и остальные атрибуты кнопки не меняем. -->
      <xpath expr="//button[@name='action_arrange_delivery']" position="attributes">
        <attribute name="name">action_open_delivery_tracking_wizard</attribute>
        <attribute name="confirm"></attribute>
      </xpath>
    </field>
  </record>

  <record id="view_purchase_order_form_inherit_delivery_fields" model="ir.ui.view">
    <field name="name">purchase.order.form.inherit.delivery.tracking.fields</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
      <!-- Рядом с уже существующими полями доставки (incoterm, тип складской
           операции), которые purchase_stock добавляет в ту же group на
           вкладке "Прочая информация" (purchase_delivery_invoice). -->
      <xpath expr="//page[@name='purchase_delivery_invoice']/group/group" position="inside">
        <field name="delivery_method_id" options="{'no_quick_create': false}"/>
        <field name="tracking_number" invisible="not delivery_method_id.has_tracking"/>
        <field name="tracking_url" widget="url" string="Ссылка отслеживания" invisible="not tracking_url"/>
        <field name="shipped_date"/>
      </xpath>
    </field>
  </record>

  <record id="view_purchase_registry_list_inherit_delivery_tracking" model="ir.ui.view">
    <field name="name">purchase.order.registry.list.inherit.delivery.tracking</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase_pdf_import.view_purchase_registry_list"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='user_id']" position="after">
        <field name="delivery_summary" string="Доставка" optional="hide"/>
      </xpath>
    </field>
  </record>

  <record id="view_purchase_registry_search_inherit_delivery_tracking" model="ir.ui.view">
    <field name="name">purchase.order.registry.search.inherit.delivery.tracking</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase_pdf_import.view_purchase_registry_search"/>
    <field name="arch" type="xml">
      <xpath expr="//filter[@name='group_partner']" position="after">
        <filter string="Способ доставки" name="group_delivery_method" context="{'group_by': 'delivery_method_id'}"/>
      </xpath>
    </field>
  </record>
</odoo>
